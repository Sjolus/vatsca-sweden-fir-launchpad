<Window x:Class="VatscaUpdateChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:VatscaUpdateChecker.Models"
        Icon="Assets/app.ico"
        Title="Sweden FIR Launchpad"
        Height="415" Width="695"
        MinHeight="415" MinWidth="695"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Background="{DynamicResource AppBg}">

    <Window.Resources>

        <!-- Flat button base style -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Profile picker — ghost button with border, secondary to Launch -->
        <Style x:Key="ProfilePickerButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button — turns red on hover -->
        <Style x:Key="CloseButton" BasedOn="{StaticResource FlatButton}" TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b63f3f"/>
                    <Setter Property="Opacity"    Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Status badge colours via DataTriggers — brand colours, same in both themes -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Background" Value="#484b4c"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CheckStatus.UpToDate}">
                    <Setter Property="Background" Value="#41826e"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CheckStatus.UpdateAvailable}">
                    <Setter Property="Background" Value="#b63f3f"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CheckStatus.Checking}">
                    <Setter Property="Background" Value="#1a475f"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CheckStatus.Unsupported}">
                    <Setter Property="Background" Value="#ff9800"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CheckStatus.Error}">
                    <Setter Property="Background" Value="#ff9800"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
    <DockPanel>

        <!-- ── Header ── -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}" Padding="16,8"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/logo-banner.png" Height="38" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text=" Sweden FIR Launchpad" Foreground="White" FontSize="17" FontWeight="Light"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleButton"
                            Content="☽"
                            Style="{StaticResource FlatButton}"
                            Background="{DynamicResource ThemeToggleBg}" Foreground="White"
                            Padding="10,6" FontSize="14" Margin="0,0,8,0"
                            ToolTip="Toggle dark / light mode"
                            Click="ThemeToggle_Click"/>
                    <Button x:Name="AppConfigButton"
                            Content="⚙  App Config"
                            Style="{StaticResource FlatButton}"
                            Background="#1a475f" Foreground="White"
                            Padding="12,6" FontSize="12" Margin="0,0,8,0"
                            Click="AppConfig_Click"/>
                    <Button Content="⚙  Settings"
                            Style="{StaticResource FlatButton}"
                            Background="#1a475f" Foreground="White"
                            Padding="12,6" FontSize="12"
                            Click="Settings_Click"/>
                    <!-- Window controls -->
                    <Button Content="─"
                            Style="{StaticResource FlatButton}"
                            Background="#1a475f" Foreground="White"
                            Padding="12,6" FontSize="12" Margin="12,0,2,0"
                            ToolTip="Minimise"
                            Click="Minimize_Click"/>
                    <Button Content="✕"
                            Style="{StaticResource CloseButton}"
                            Background="#1a475f" Foreground="White"
                            Padding="12,6" FontSize="12"
                            ToolTip="Close"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Footer ── -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource FooterBg}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Button x:Name="CheckButton"
                        Content="↻  Check for Updates"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Style="{StaticResource FlatButton}"
                        Background="#1a475f" Foreground="White"
                        Padding="14,7" FontSize="13" FontWeight="Medium"
                        Click="Check_Click"/>
                <TextBlock x:Name="LastCheckedText"
                           Text="Last checked: never"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ── Column headers ── -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ColumnHeaderBg}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="175"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Application" Padding="8,7"  FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="Installed"   Padding="8,7"  FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" FontSize="12"/>
                <TextBlock Grid.Column="3" Text="Latest"      Padding="8,7"  FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" FontSize="12"/>
                <TextBlock Grid.Column="4" Text="Status"      Padding="8,7"  FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ── App rows ── -->
        <ItemsControl x:Name="AppList" Background="{DynamicResource AppBg}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:CheckResult}">

                    <Border Background="{Binding IsFolder, Converter={StaticResource RowBgConverter}}"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="175"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon button: Launch / Kill / Open Folder (non-EuroScope rows) -->
                            <Button Grid.Column="0"
                                    Visibility="{Binding ShowSimpleLaunch, Converter={StaticResource BoolToVisibility}}"
                                    Click="Launch_Click"
                                    Foreground="White"
                                    Padding="9,5" Margin="8,8,4,8"
                                    FontSize="11"
                                    VerticalAlignment="Center"
                                    ToolTip="{Binding LaunchTooltip}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource FlatButton}" TargetType="Button">
                                        <Setter Property="Content" Value="▶"/>
                                        <Setter Property="Background" Value="#1a475f"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Content" Value="■"/>
                                                <Setter Property="Background" Value="#b63f3f"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                <Setter Property="Content" Value="📁"/>
                                                <Setter Property="Background" Value="#484b4c"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Split button: Launch | Profile picker (EuroScope only) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        Visibility="{Binding ShowSplitLaunch, Converter={StaticResource BoolToVisibility}}"
                                        VerticalAlignment="Center" Margin="8,8,4,8">
                                <Button Click="Launch_Click" Foreground="White"
                                        Padding="9,5" FontSize="11"
                                        ToolTip="{Binding LaunchTooltip}">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource FlatButton}" TargetType="Button">
                                            <Setter Property="Content" Value="▶"/>
                                            <Setter Property="Background" Value="#1a475f"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Content" Value="■"/>
                                                    <Setter Property="Background" Value="#b63f3f"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Border Width="1" Background="White" Opacity="0.2" Margin="0,3"/>
                                <Button Click="ProfileDropdown_Click" Foreground="White"
                                        Content="▾" Padding="6,5" FontSize="10"
                                        ToolTip="{Binding SelectedProfile.DisplayName}">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource FlatButton}" TargetType="Button">
                                            <Setter Property="Background" Value="#1a475f"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#b63f3f"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- App name + running indicator dot -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0,8,0">
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#D5D8DC"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Fill" Value="#41826e"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding AppName}"
                                           FontWeight="Medium" Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center" Padding="0,13"/>
                            </StackPanel>

                            <!-- Installed version -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding InstalledVersion}"
                                       Padding="8,13" Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"/>

                            <!-- Latest version -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding LatestVersion}"
                                       Padding="8,13" Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"/>

                            <!-- Status badge + inline download icon -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                <Border Style="{StaticResource StatusBadge}"
                                        ToolTip="{Binding StatusMessage}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="White" FontSize="11" FontWeight="Medium"/>
                                </Border>
                                <Button Visibility="{Binding ShowDownload, Converter={StaticResource BoolToVisibility}}"
                                        Tag="{Binding DownloadUrl}"
                                        Click="Download_Click"
                                        Content="↓"
                                        Style="{StaticResource FlatButton}"
                                        Background="#b63f3f" Foreground="White"
                                        Padding="7,3" Margin="4,0,0,0"
                                        FontSize="13" FontWeight="SemiBold"
                                        VerticalAlignment="Center"
                                        ToolTip="Download"/></StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>
    </Border>
</Window>
