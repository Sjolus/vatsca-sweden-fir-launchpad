<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Layout brushes ── -->
    <SolidColorBrush x:Key="AppBg"            Color="#071828"/>
    <SolidColorBrush x:Key="HeaderBg"         Color="#011328"/>  <!-- Tertiary — same in both themes -->
    <SolidColorBrush x:Key="ColumnHeaderBg"   Color="#0a1e2e"/>
    <SolidColorBrush x:Key="RowBg"            Color="#0d2235"/>
    <SolidColorBrush x:Key="RowAltBg"         Color="#091a29"/>
    <SolidColorBrush x:Key="FooterBg"         Color="#071828"/>
    <SolidColorBrush x:Key="DividerBrush"     Color="#1a3448"/>

    <!-- ── Text brushes ── -->
    <SolidColorBrush x:Key="PrimaryText"      Color="#dfebeb"/>  <!-- Snow -->
    <SolidColorBrush x:Key="SecondaryText"    Color="#8ca0ad"/>

    <!-- ── Input brushes ── -->
    <SolidColorBrush x:Key="InputBg"          Color="#0d2235"/>
    <SolidColorBrush x:Key="InputFg"          Color="#dfebeb"/>
    <SolidColorBrush x:Key="InputBorder"      Color="#2a4a5f"/>

    <!-- ── Theme toggle ── -->
    <SolidColorBrush x:Key="ThemeToggleBg"    Color="#1a475f"/>

    <!-- ── Implicit input styles ── -->
    <Style TargetType="TextBox">
        <Setter Property="Background"   Value="{DynamicResource InputBg}"/>
        <Setter Property="Foreground"   Value="{DynamicResource InputFg}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource InputBorder}"/>
        <Setter Property="CaretBrush"   Value="{DynamicResource InputFg}"/>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background"   Value="{DynamicResource InputBg}"/>
        <Setter Property="Foreground"   Value="{DynamicResource InputFg}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource InputBorder}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background"   Value="{DynamicResource InputBg}"/>
        <Setter Property="Foreground"   Value="{DynamicResource InputFg}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource InputBorder}"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background"   Value="{DynamicResource InputBg}"/>
        <Setter Property="Foreground"   Value="{DynamicResource InputFg}"/>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background"   Value="{DynamicResource InputBg}"/>
        <Setter Property="Foreground"   Value="{DynamicResource InputFg}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource InputBorder}"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
        <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
        <Setter Property="Padding"     Value="12,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource InputBorder}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource InputBorder}" Margin="8,3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
