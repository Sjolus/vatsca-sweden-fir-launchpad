<Window x:Class="VatscaUpdateChecker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="490" Width="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}">

    <DockPanel Margin="20">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="80" Margin="0,0,8,0"
                    Click="Save_Click"
                    Background="#1a475f" Foreground="White"
                    BorderThickness="0" Padding="0,7" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" Padding="0,7" Cursor="Hand"/>
        </StackPanel>

        <!-- Path fields -->
        <StackPanel>

            <!-- Startup behaviour -->
            <CheckBox x:Name="CheckOnStartup" Content="Check for updates automatically on startup"
                      Margin="0,0,0,20" Foreground="{DynamicResource PrimaryText}"/>

            <!-- EuroScope exe -->
            <TextBlock Text="EuroScope Executable" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="EuroscopeExePath" Grid.Column="0" Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <Button  Grid.Column="2" Content="Default" Padding="8,5" Cursor="Hand"
                         Click="InsertDefault_Click" Tag="EuroScope"/>
                <Button  Grid.Column="4" Content="✕" Padding="8,5" Cursor="Hand"
                         Click="Clear_Click" Tag="EuroScope"/>
                <Button  Grid.Column="6" Content="Browse…" Padding="10,5" Cursor="Hand"
                         Click="BrowseExe_Click" Tag="EuroScope"/>
            </Grid>

            <!-- EuroScope data folder -->
            <TextBlock Text="EuroScope Data Folder" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="EuroscopePath" Grid.Column="0" Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <Button  Grid.Column="2" Content="Default" Padding="8,5" Cursor="Hand"
                         Click="InsertDefault_Click" Tag="EuroscopeData"/>
                <Button  Grid.Column="4" Content="✕" Padding="8,5" Cursor="Hand"
                         Click="Clear_Click" Tag="EuroscopeData"/>
                <Button  Grid.Column="6" Content="Browse…" Padding="10,5" Cursor="Hand"
                         Click="BrowseFolder_Click"/>
            </Grid>
            <TextBlock Text="Select the folder containing ESAA-Sweden_*.sct"
                       FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,16"/>

            <!-- TrackAudio -->
            <TextBlock Text="TrackAudio Executable" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TrackAudioPath" Grid.Column="0" Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <Button  Grid.Column="2" Content="Default" Padding="8,5" Cursor="Hand"
                         Click="InsertDefault_Click" Tag="TrackAudio"/>
                <Button  Grid.Column="4" Content="✕" Padding="8,5" Cursor="Hand"
                         Click="Clear_Click" Tag="TrackAudio"/>
                <Button  Grid.Column="6" Content="Browse…" Padding="10,5" Cursor="Hand"
                         Click="BrowseExe_Click" Tag="TrackAudio"/>
            </Grid>

            <!-- VACS -->
            <TextBlock Text="VACS Executable" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="VacsPath" Grid.Column="0" Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <Button  Grid.Column="2" Content="Default" Padding="8,5" Cursor="Hand"
                         Click="InsertDefault_Click" Tag="VACS"/>
                <Button  Grid.Column="4" Content="✕" Padding="8,5" Cursor="Hand"
                         Click="Clear_Click" Tag="VACS"/>
                <Button  Grid.Column="6" Content="Browse…" Padding="10,5" Cursor="Hand"
                         Click="BrowseExe_Click" Tag="VACS"/>
            </Grid>

            <!-- vATIS -->
            <TextBlock Text="vATIS Executable" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="VatisPath" Grid.Column="0" Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <Button  Grid.Column="2" Content="Default" Padding="8,5" Cursor="Hand"
                         Click="InsertDefault_Click" Tag="vATIS"/>
                <Button  Grid.Column="4" Content="✕" Padding="8,5" Cursor="Hand"
                         Click="Clear_Click" Tag="vATIS"/>
                <Button  Grid.Column="6" Content="Browse…" Padding="10,5" Cursor="Hand"
                         Click="BrowseExe_Click" Tag="vATIS"/>
            </Grid>

        </StackPanel>
    </DockPanel>
</Window>
