<Window x:Class="VatscaUpdateChecker.AppConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App Configuration"
        Height="580" Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}">

    <DockPanel Margin="20">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Preview" Width="80" Margin="0,0,8,0"
                    Click="Preview_Click" Padding="0,7" Cursor="Hand"/>
            <Button Content="Save &amp; Apply" Width="100" Margin="0,0,8,0"
                    Click="Save_Click"
                    Background="#1a475f" Foreground="White"
                    BorderThickness="0" Padding="0,7" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" Padding="0,7" Cursor="Hand"/>
        </StackPanel>

        <!-- Sync status banner -->
        <Border x:Name="SyncBanner" DockPanel.Dock="Top"
                Padding="10,8" Margin="0,0,0,16">
            <TextBlock x:Name="SyncText" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Fields -->
        <StackPanel>

            <!-- Name -->
            <TextBlock Text="Full Name" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <TextBox x:Name="NameBox" Margin="0,0,0,14" Padding="6,5" FontFamily="Consolas" FontSize="12"/>

            <!-- Rating -->
            <TextBlock Text="VATSIM Rating" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <ComboBox x:Name="RatingBox" Margin="0,0,0,14" Padding="6,5" FontSize="12"/>

            <!-- CID -->
            <TextBlock Text="VATSIM CID" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <TextBox x:Name="CidBox" Margin="0,0,0,14" Padding="6,5" FontFamily="Consolas" FontSize="12"/>

            <!-- Password -->
            <TextBlock Text="VATSIM Password" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="PasswordBox"    Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <TextBox    x:Name="PasswordBoxText" Padding="6,5" FontFamily="Consolas" FontSize="12"
                             Visibility="Collapsed"/>
                <Button Grid.Column="1" x:Name="TogglePassword" Content="Show"
                        Padding="8,5" Margin="4,0,0,0" Cursor="Hand"
                        Click="TogglePassword_Click"/>
            </Grid>
            <TextBlock Text="Stored securely in Windows Credential Manager"
                       FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,14"/>

            <!-- Hoppie Code -->
            <TextBlock Text="Hoppie ACARS Code" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="HoppieBox"     Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <TextBox    x:Name="HoppieBoxText"  Padding="6,5" FontFamily="Consolas" FontSize="12"
                             Visibility="Collapsed"/>
                <Button Grid.Column="1" x:Name="ToggleHoppie" Content="Show"
                        Padding="8,5" Margin="4,0,0,0" Cursor="Hand"
                        Click="ToggleHoppie_Click"/>
            </Grid>
            <TextBlock Text="Stored securely in Windows Credential Manager"
                       FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,14"/>

            <!-- OBS Callsign -->
            <TextBlock Text="OBS Callsign Prefix" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryText}"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ObsBox" Padding="6,5" FontFamily="Consolas" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="_OBS" VerticalAlignment="Center"
                           Margin="6,0,0,0" Foreground="{DynamicResource SecondaryText}"
                           FontFamily="Consolas" FontSize="12"/>
            </Grid>
            <TextBlock Text="e.g. enter ES → saved as ES_OBS in LoginProfiles.txt"
                       FontSize="11" Foreground="{DynamicResource SecondaryText}"/>

        </StackPanel>
    </DockPanel>
</Window>
